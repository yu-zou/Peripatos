{
  "llm": {
    "base_url": "https://router.requesty.ai/v1",
    "api_key": "YOUR_REQUESTY_API_KEY_HERE",
    "model": "openai/gpt-4o-mini"
  },
  "tts": {
    "provider": "edge",
    "voices": {
      "host": "en-US-GuyNeural",
      "interviewee": "en-US-AriaNeural"
    }
  },
  "defaults": {
    "archetype": "peer",
    "output_dir": "."
  },
  "rag": {
    "embedding_model": "text-embedding-3-small",
    "chunk_size": 1000,
    "chunk_overlap": 200,
    "top_k": 5,
    "cache_dir": null
  }
}
