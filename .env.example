# Peripatos Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenAI API Configuration
# Required for: GPT-4 dialogue generation, Text-to-Speech (primary)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Configuration
# Required for: Claude models (alternative to OpenAI for dialogue generation)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenRouter API Configuration
# Unified API gateway for multiple LLM providers (OpenAI, Anthropic, Llama, etc.)
# Model names use provider/model format, e.g., openai/gpt-4o or meta-llama/llama-2-70b-chat
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Google Gemini API Configuration
# Google's Gemini AI models for dialogue generation (alternative LLM provider)
# Example models: gemini-2.0-flash (fast), gemini-1.5-pro (advanced reasoning)
# Get your key at: https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key-here

# Environment Type
# development: Enables verbose logging, detailed error messages, and debug output for development workflows
# production: Minimal logging, concise error messages, optimized for end-user experience and performance
# testing: Used by test suite, may mock external services to ensure fast, isolated test execution
ENVIRONMENT=development

# Output Directory
# Where generated audio files and metadata will be saved
OUTPUT_DIR=output/

# Logging Level
# DEBUG: All messages including internal state — useful for debugging API calls, parsing, and data flow
# INFO: General progress messages (default) — shows pipeline stages, model selection, and processing steps
# WARNING: Only potential issues — e.g., fallback behaviors triggered, retries in progress
# ERROR: Only failures — API errors, parsing failures, missing required fields
# CRITICAL: Only fatal errors that stop execution — system initialization failures, unreachable services
LOG_LEVEL=INFO
