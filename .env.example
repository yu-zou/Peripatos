# Peripatos Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenAI API Configuration
# Required for: GPT-4 dialogue generation, Text-to-Speech (primary)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Configuration
# Required for: Claude models (alternative to OpenAI for dialogue generation)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Environment Type
# Options: development, production, testing
ENVIRONMENT=development

# Output Directory
# Where generated audio files and metadata will be saved
OUTPUT_DIR=output/

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
